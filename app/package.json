{
  "name": "drizzle-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:setup": "npm run db:migrate && npm run seed",
    "seed": "tsx src/lib/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "next": "^13.4.8",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.4.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.2.2",
    "vitest": "^3.2.3"
  }
}
